{
  "name": "groq",
  "version": "6.5.0",
  "description": "Tagged template literal for Sanity.io GROQ-queries",
  "keywords": [
    "cms",
    "content",
    "groq",
    "headless",
    "literal",
    "realtime",
    "sanity",
    "string",
    "tagged",
    "template"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/sanity.git",
    "directory": "packages/groq"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./lib/groq.d.ts",
  "exports": {
    ".": {
      "monorepo": "./src/_exports.ts",
      "default": "./lib/groq.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./lib/groq.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check:types": "(cd ../.. && tsgo --project packages/groq/tsconfig.lib.json --erasableSyntaxOnly)",
    "prepublishOnly": "turbo run build",
    "pretest": "run-s build",
    "test": "node --test",
    "watch": "tsdown --watch"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@repo/tsdown.config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:"
  },
  "browserslist": [
    "node >=22.12",
    "baseline 2024"
  ],
  "engines": {
    "node": ">=22.12"
  }
}
