{
  "name": "@repo/debug-proxy",
  "version": "6.5.0",
  "private": true,
  "description": "Local debugging proxy for the Sanity API — simulate latency, SSE faults, and error responses",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "bin": {
    "debug-proxy": "./src/cli.ts"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check:types": "(cd ../../.. && tsgo --project packages/@repo/debug-proxy/tsconfig.json --erasableSyntaxOnly)",
    "dev": "tsx watch --env-file-if-exists=.env src/cli.ts",
    "start": "tsx --env-file-if-exists=.env src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@optique/core": "catalog:",
    "@optique/run": "catalog:",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "es-toolkit": "^1.49.0",
    "eventsource-parser": "^3.1.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@repo/test-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsx": "^4.23.1",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.18"
  }
}
