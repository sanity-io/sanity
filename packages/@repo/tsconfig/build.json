{
  "$schema": "https://json.schemastore.org/tsconfig",
  "description": "The shared configuration used by tsdown to build workspaces and generate dts files",
  "extends": "./base.json",
  "compilerOptions": {
    "noEmitOnError": true,
    // The published packages ship compiled JSX (the `jsx: 'preserve'` in base.json is for source
    // that studio bundlers compile themselves); rolldown reads this to compile JSX with the
    // automatic runtime during builds
    "jsx": "react-jsx",
    // every package must declare this, by setting this here we ensure that accidents will write to ./node_modules/.sanity-monorepo/dts instead of generating .d.ts files that are colocated if `outDir` is accidentally missing
    "outDir": "./node_modules/.sanity-monorepo/dts"
  }
}
