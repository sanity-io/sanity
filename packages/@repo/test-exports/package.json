{
  "name": "@repo/test-exports",
  "version": "5.18.0",
  "private": true,
  "description": "Ensures that all the monorepo packages that are published works in native node ESM and CJS runtimes, with some exceptions for entrypoints designed to be handled by bundlers (CSS and other assets)",
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --import ./test/mock-browser-env.mjs --test"
  },
  "dependencies": {
    "@sanity/diff": "workspace:*",
    "@sanity/mutator": "workspace:*",
    "@sanity/schema": "workspace:*",
    "@sanity/types": "workspace:*",
    "@sanity/util": "workspace:*",
    "@sanity/vision": "workspace:*",
    "groq": "workspace:*",
    "sanity": "workspace:*"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "node-test-github-reporter": "^1.3.1"
  }
}
