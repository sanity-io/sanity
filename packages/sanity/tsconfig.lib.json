{
  "extends": "./tsconfig.settings.json",
  "include": ["./package.json", "./src", "./typings"],
  "exclude": [
    "./src/**/__fixtures__",
    "./src/**/__mocks__",
    "./src/**/__test__",
    "./src/**/__tests__",
    "./src/**/*.test.ts",
    "./src/**/*.test.tsx",
    "./src/**/*.test-d.ts",
    "./src/**/*.test-d.tsx",
    "./src/**/vitest.config.mts"
  ],
  "compilerOptions": {
    "customConditions": ["monorepo"],
    // The published package ships compiled JSX (`jsx: 'preserve'` in the settings is for source
    // that studio bundlers compile themselves); rolldown reads this to compile JSX with the
    // automatic runtime during builds
    "jsx": "react-jsx"
  }
}
