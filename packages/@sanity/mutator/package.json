{
  "name": "@sanity/mutator",
  "version": "6.5.0",
  "description": "A set of models to make it easier to utilize the powerful real time collaborative features of Sanity",
  "keywords": [
    "cms",
    "content",
    "headless",
    "mutator",
    "realtime",
    "sanity"
  ],
  "homepage": "https://www.sanity.io/",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/sanity.git",
    "directory": "packages/@sanity/mutator"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "monorepo": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./lib/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check:types": "(cd ../../.. && tsgo --project packages/@sanity/mutator/tsconfig.lib.json --erasableSyntaxOnly)",
    "clean": "rimraf lib",
    "perf": "node ./perf/run.cjs",
    "prepublishOnly": "turbo run build",
    "test": "vitest run",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@sanity/diff-match-patch": "^3.2.0",
    "@sanity/types": "workspace:*",
    "@sanity/uuid": "^3.0.3",
    "debug": "^4.4.3",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@repo/test-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@repo/tsdown.config": "workspace:*",
    "@types/debug": "^4.1.13",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "browserslist": [
    "node >=22.12",
    "baseline 2024"
  ]
}
