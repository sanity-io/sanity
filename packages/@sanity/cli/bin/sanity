#!/usr/bin/env node
import {createRequire} from 'node:module'

const require = createRequire(import.meta.url)

process.on('unhandledRejection', (error) => {
  console.error(error)
  process.exit(1)
})

if (process.env.SANITY_CLI_RUN_FROM_SOURCE === '1') {
  require('./dev.cjs')
} else {
  // run cli
  require('../lib/run.js')
}
