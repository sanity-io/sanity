  "private": true,
  "description": "Sanity Studio perf tests",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "(cd studio && pnpm build)",
    "perf:codegen": "tsx -r dotenv/config codegen.ts",
    "perf:test": "tsx cli.ts",
    "perf:test:ci": "tsx cli.ts",
    "studio": "cd perf/studio && (pnpm build && pnpm start)",
    "studio:dev": "cd perf/studio && SANITY_STUDIO_DATASET=dev pnpm dev"
  },
  "dependencies": {
    "@playwright/test": "catalog:",
    "@sanity/client": "catalog:",
    "@sanity/uuid": "^3.0.3",
    "dotenv": "^17.4.2",
    "lodash-es": "^4.18.1",
    "rxjs": "^7.8.2",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@repo/test-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "esbuild": "0.28.1",
    "tsx": "^4.23.1",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
