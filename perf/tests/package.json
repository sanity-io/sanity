{
  "name": "sanity-perf-tests",
  "version": "5.25.2",
  "private": true,
  "description": "Sanity Studio perf tests",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "scripts": {
    "build": "(cd studio && pnpm build)",
    "lint": "eslint .",
    "perf:codegen": "tsx -r dotenv/config codegen.ts",
    "perf:test": "tsx cli.ts",
    "perf:test:ci": "tsx cli.ts",
    "studio": "cd perf/studio && (pnpm build && pnpm start)",
    "studio:dev": "cd perf/studio && SANITY_STUDIO_DATASET=dev pnpm dev"
  },
  "dependencies": {
    "@playwright/test": "catalog:",
    "@sanity/client": "catalog:",
    "@sanity/uuid": "^3.0.2",
    "dotenv": "^16.6.1",
    "lodash-es": "^4.18.1",
    "rxjs": "^7.8.2",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/test-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "esbuild": "0.28.0",
    "eslint": "catalog:",
    "tsx": "^4.21.0",
    "vitest": "catalog:"
  }
}
