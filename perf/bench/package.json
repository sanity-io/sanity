{
  "name": "bench",
  "version": "6.3.0",
  "private": true,
  "description": "Hermetic studio performance benchmark suite (eFPS replacement)",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "module",
  "scripts": {
    "build": "sanity build",
    "build:reference-config": "SANITY_STUDIO_BENCH_API_HOST=https://localhost:4312 SANITY_STUDIO_BENCH_PROJECT_ID=benchref sanity build .reference/dist",
    "check:types": "(cd ../.. && tsgo --project perf/bench/tsconfig.json --noEmit)",
    "cli": "./cli/index.ts",
    "dev": "./cli/index.ts dev",
    "report": "./cli/index.ts report",
    "store": "./cli/index.ts store",
    "test": "./cli/index.ts run",
    "unit": "vitest run",
    "unit:watch": "vitest"
  },
  "dependencies": {
    "@optique/core": "catalog:",
    "@optique/run": "catalog:",
    "@repo/debug-proxy": "workspace:*",
    "@repo/utils": "workspace:*",
    "@sanity/client": "catalog:",
    "@sanity/mutator": "workspace:*",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "chalk": "^5.6.2",
    "esbuild": "0.28.1",
    "groq-js": "^1.30.3",
    "mendoza": "^3.0.8",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "^7.8.2",
    "sanity": "workspace:*",
    "sanity-plugin-internationalized-array": "^5.1.21",
    "styled-components": "catalog:",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@repo/test-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
