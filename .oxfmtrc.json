{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "bracketSpacing": false,
  "quoteProps": "consistent",
  "sortImports": {
    "groups": [
      ["side_effect", "side_effect_style"],
      ["builtin", "subpath"],
      ["external"],
      ["internal"],
      "unknown",
      ["parent", "sibling", "index", "style"]
    ],
    "newlinesBetween": true,
    "sortSideEffects": false
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "overrides": [
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "singleQuote": false
      }
    }
  ],
  "ignorePatterns": ["pnpm-workspace.yaml"]
}
