{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "reportUnusedDisableDirectives": "error"
  },
  "env": {
    "node": true,
    "browser": true
  },
  "plugins": [
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "oxc",
    "import",
    "jsx-a11y",
    "node",
    "promise"
  ],
  "jsPlugins": [
    {"name": "tsdoc", "specifier": "eslint-plugin-tsdoc"},
    {"name": "i18next", "specifier": "eslint-plugin-i18next"},
    {"name": "@sanity/i18n", "specifier": "@sanity/eslint-plugin-i18n"},
    {"name": "boundaries", "specifier": "eslint-plugin-boundaries"},
    {"name": "testing-library", "specifier": "eslint-plugin-testing-library"}
  ],
  "settings": {
    "import/resolver": {
      "typescript": true,
      "node": true
    },
    "boundaries/root-path": "packages/sanity",
    "boundaries/include": ["src/**/*.*"],
    "boundaries/elements": [
      {"type": "sanity", "pattern": ["src/_exports/index.ts"], "mode": "full"},
      {"type": "sanity__contents", "pattern": ["src/core/**/*.*"], "mode": "full"},
      {"type": "sanity/_internal", "pattern": ["src/_exports/_internal.ts"], "mode": "full"},
      {"type": "sanity/_internal__contents", "pattern": ["src/_internal/**/*.*"], "mode": "full"},
      {"type": "sanity/cli", "pattern": ["src/_exports/cli.ts"], "mode": "full"},
      {"type": "sanity/cli__contents", "pattern": ["src/cli/**/*.*"], "mode": "full"},
      {"type": "sanity/desk", "pattern": ["src/_exports/desk.ts"], "mode": "file"},
      {"type": "sanity/desk__contents", "pattern": ["src/desk/**/*.*"], "mode": "file"},
      {"type": "sanity/router", "pattern": ["src/_exports/router.ts"], "mode": "full"},
      {"type": "sanity/router__contents", "pattern": ["src/router/**/*.*"], "mode": "full"},
      {"type": "sanity/structure", "pattern": ["src/_exports/structure.ts"], "mode": "file"},
      {"type": "sanity/structure__contents", "pattern": ["src/structure/**/*.*"], "mode": "file"},
      {"type": "sanity/_singletons", "pattern": ["src/_exports/_singletons.ts"], "mode": "file"},
      {
        "type": "sanity/_singletons__contents",
        "pattern": ["src/_singletons/**/*.*"],
        "mode": "full"
      }
    ]
  },
  "ignorePatterns": [
    "**/etc/*",
    "**/.sanity/*",
    "**/public/*",
    "**/build/*",
    "**/.next/*",
    "**/static/*",
    "**/coverage/*",
    "**/lib/*",
    "**/node_modules/*",
    "**/dist/*",
    "*.json",
    "*.css",
    "*.snap",
    "*.md",
    "dev/test-studio/sanity.theme.mjs",
    // Out of scope for type checking (SGH-461); examples are not CI-gated
    "examples/**",
    // Intentional .test-d.ts / expectTypeOf fixtures — vitest typechecks these separately
    "packages/@repo/test-dts-exports/**",
    // Export smoke tests that intentionally exercise package entry shapes
    "packages/@repo/test-exports/**",
    // AILF reference solutions are fixtures, not app source
    "packages/@repo/ailf/.ailf/tasks/*.reference.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "styled-components",
            "importNames": ["default"],
            "message": "Please use `import {styled} from 'styled-components'` instead."
          },
          {
            "name": "styled-components",
            "importNames": ["ServerStyleSheet"],
            "message": "ServerStyleSheet from styled-components breaks compatibility with @sanity/css-in-js and is bad for performance."
          },
          {
            "name": "react",
            "importNames": ["default"],
            "message": "Please use named imports, e.g. `import {useEffect, useMemo, type ComponentType} from 'react'` instead."
          },
          {
            "name": "react",
            "importNames": ["createElement"],
            "message": "Please use JSX instead of createElement, for example `createElement(Icon)` should be `<Icon />`"
          },
          {
            "name": "react",
            "importNames": ["createRef"],
            "message": "Please use useRef instead of createRef, unless it's for a legacy React.Component class"
          },
          {
            "name": "react/jsx-runtime",
            "message": "Do not attempt importing from the jsx runtime manually, instead use JSX syntax and let the bundler transform it"
          },
          {
            "name": "react/jsx-dev-runtime",
            "message": "Do not attempt importing from the jsx runtime manually, instead use JSX syntax and let the bundler transform it"
          },
          {
            "name": "react/compiler-runtime",
            "message": "Do not attempt importing from the compiler runtime manually, instead let react compiler transform it"
          },
          {
            "name": "date-fns",
            "message": "Import from individual modules instead, e.g. `import {startOfDay} from 'date-fns/startOfDay'`. Barrel imports are ~50% slower."
          },
          {
            "name": "lodash-es",
            "message": "Import from individual modules instead, e.g. `import debounce from 'lodash-es/debounce.js'`. Barrel imports are ~55% slower."
          }
        ],
        "patterns": [
          {
            "group": ["**/scheduled-publishing/**"],
            "message": "Importing from scheduled-publishing folder is discouraged since we are dropping support for it in the near future"
          },
          {
            "group": ["lodash.*", "lodash/*", "lodash"],
            "message": "Please use individual imports from 'lodash-es' instead, e.g. `import debounce from 'lodash-es/debounce.js'`."
          },
          {
            "group": ["lodash-es/*", "!lodash-es/*.js"],
            "message": "lodash-es submodule imports must include the .js extension, e.g. `import debounce from 'lodash-es/debounce.js'`."
          }
        ]
      }
    ],
    "typescript/ban-ts-comment": "error",
    "typescript/prefer-ts-expect-error": "error",
    "react/jsx-key": "error",
    "unicorn/no-abusive-eslint-disable": "error",
    // Not relevant as we use the modern jsx-runtime transform
    "react-in-jsx-scope": "off",
    // Not relevant due to React Compiler
    "react_perf/jsx-no-new-array-as-prop": "off",
    "react_perf/jsx-no-new-object-as-prop": "off",
    "react_perf/jsx-no-new-function-as-prop": "off",
    "react_perf/jsx-no-jsx-as-prop": "off",
    // False negatives
    "jsx_a11y/anchor-is-valid": "off",
    "jest/no-conditional-expect": "off",
    "jest/no-standalone-expect": "off",
    "jest/no-commented-out-tests": "off",
    "jest/no-disabled-tests": "off",
    "jest/require-to-throw-message": "off",
    "jest/no-export": "off",
    "jest/expect-expect": "off",
    "jest/valid-expect": "off",
    "jest/valid-title": "off",
    "jest/valid-describe-callback": "off",
    "vitest/no-disabled-tests": "off",
    "vitest/no-test-prefixes": "off",
    "jsx_a11y/no-autofocus": "off",
    "jsx_a11y/no-static-element-interactions": "off", // Allow event handlers on static elements
    "unicorn/require-post-message-target-origin": "off", // disabled since it can't distinguish between `window.postMessage` and node `Worker#postMessage`
    // Handy rules that are disabled by default
    "react/exhaustive-deps": "error",
    "react/rules-of-hooks": "error",
    // React Compiler rules, native nursery rule (replaces eslint-plugin-react-hooks compiler rules).
    // Pre-existing violations are grandfathered with inline `oxlint-disable-next-line` suppressions.
    "react/react-compiler": "error",
    // Import hygiene previously enforced by eslint-plugin-import
    "import/first": "error",
    "import/newline-after-import": "error",
    "import/no-duplicates": ["error", {"prefer-inline": true}],
    "import/consistent-type-specifier-style": ["error", "prefer-inline"],
    "import/extensions": [
      "error",
      {
        "pattern": {"cjs": "always", "json": "always"},
        "pathGroupOverrides": [{"pattern": "lodash-es/*", "action": "ignore"}]
      }
    ],
    // Consistent inline type imports (was @typescript-eslint/consistent-type-imports)
    "typescript/consistent-type-imports": [
      "error",
      {"prefer": "type-imports", "fixStyle": "inline-type-imports"}
    ],
    "typescript/no-dupe-class-members": "error",
    // unicorn rules previously enabled as error via eslint-config-sanity
    "unicorn/prefer-string-slice": "error",
    "unicorn/prefer-node-protocol": "error",
    "unicorn/prefer-keyboard-event-key": "error",
    "unicorn/custom-error-definition": "error",
    // tsdoc syntax validation (loaded via jsPlugins).
    // TODO(oxlint): staged as warn; the JS plugin doesn't yet pick up packages/sanity/tsdoc.json
    // custom tag definitions (@hidden/@todo/@alias), so it would otherwise report false positives.
    "tsdoc/syntax": "warn",
    "eslint/no-console": ["error", {"allow": ["warn", "error"]}],
    // Keep disabled: `_id` and other underscore-prefixed API fields are intentional.
    "eslint/no-underscore-dangle": "off",
    // We no longer allow commonjs as we ship ESM only
    "import/no-commonjs": "error",
    "no-restricted-globals": [
      "error",
      {
        "name": "__dirname",
        "message": "Use path.dirname(fileURLToPath(import.meta.url)) instead"
      },
      {
        "name": "__filename",
        "message": "Use fileURLToPath(import.meta.url) instead"
      }
    ],
    // These rules should be enabled in the future, they are disabled for now to reduce the PR scope for landing oxlint
    "typescript/no-explicit-any": "warn",
    "eslint/no-await-in-loop": "warn",
    "unicorn/no-new-array": "warn",
    "unicorn/consistent-function-scoping": "warn",
    "unicorn/no-useless-spread": "warn",
    "unicorn/no-await-in-promise-methods": "warn",
    "eslint/no-useless-catch": "warn",
    "eslint/no-unneeded-ternary": "warn",
    "eslint/no-unused-vars": "warn",
    "unicorn/no-useless-fallback-in-spread": "warn",
    "import/no-named-as-default": "warn",
    "unicorn/prefer-string-starts-ends-with": "warn",
    "unicorn/no-single-promise-in-promise-methods": "warn",
    "import/no-named-as-default-member": "warn",
    "import/default": "warn",
    "oxc/no-async-endpoint-handlers": "warn",
    "unicorn/prefer-array-find": "warn",
    "jsx_a11y/alt-text": "warn",
    "eslint/no-constant-binary-expression": "warn",
    "eslint/no-extend-native": "warn",
    "jsx_a11y/anchor-has-content": "warn",
    "react/no-array-index-key": "warn",
    "oxc/no-accumulating-spread": "warn",
    "jsx_a11y/prefer-tag-over-role": "warn",
    "jsx_a11y/click-events-have-key-events": "warn",
    "jsx_a11y/role-has-required-aria-props": "warn",
    "unicorn/no-instanceof-builtins": "off",
    "jsx_a11y/aria-role": "warn",
    "jsx_a11y/label-has-associated-control": "warn",
    "unicorn/prefer-add-event-listener": "warn",
    "jsx_a11y/role-supports-aria-props": "warn",
    "unicorn/no-useless-length-check": "warn",
    "react/iframe-missing-sandbox": "warn",
    "jsx_a11y/iframe-has-title": "warn",
    "promise/no-callback-in-promise": "warn",
    "eslint/no-unsafe-optional-chaining": "warn",
    "promise/always-return": ["error", {"ignoreLastCallback": true}],
    "require-module-specifiers": "warn",
    // handy type-aware rules
    "no-unnecessary-boolean-literal-compare": "error",
    // Powerful type-aware rules that should be enabled in the future, but have too many violations to be handled in a single PR
    "no-base-to-string": "warn",
    "no-duplicate-type-constituents": "warn",
    "no-implied-eval": "warn",
    "no-misused-spread": "warn",
    "no-multiple-resolved": "warn",
    "no-redundant-type-constituents": "warn",
    "no-unnecessary-template-expression": "off",
    "no-unnecessary-type-arguments": "warn",
    // Kept off: the auto-fix strips `types: {} as {...}` declarations that xstate's `setup()`
    // requires for typing input/context/events, so `--fix` breaks type checking
    "no-unnecessary-type-assertion": "off",
    "no-unsafe-type-assertion": "warn",
    "restrict-template-expressions": "warn",
    "unbound-method": "warn",
    // TODO(oxlint): Fix violations and set these back to error.
    "react/no-unstable-nested-components": "warn",
    "typescript/no-unnecessary-type-conversion": "off",
    "typescript/no-useless-default-assignment": "off",
    "typescript/no-unnecessary-type-parameters": "off",
    "react/jsx-no-constructed-context-values": "warn",
    "react/no-object-type-as-default-prop": "warn",
    "typescript/await-thenable": "warn",
    "typescript/consistent-return": "warn",
    "eslint/no-shadow": "warn",
    "jsx_a11y/control-has-associated-label": "warn",
    "jsx_a11y/interactive-supports-focus": "off",
    "jsx_a11y/no-noninteractive-tabindex": "warn",
    // Temporarily disabled, will be re-enabled in the near term
    "unicorn/prefer-set-has": "off",
    // Requires polyfills for older browsers
    "no-array-reverse": "off",
    "no-array-sort": "off",
    "oxc/no-map-spread": "off",
    "jsx_a11y/aria-proptypes": "off"
  },
  "overrides": [
    {
      "files": ["scripts/**/*", "examples/functions/**/*"],
      "rules": {"no-console": "off", "no-unsafe-type-assertion": "off"}
    },
    {
      "files": ["**/*.test.{ts,tsx,cjs,mjs,js,jsx}"],
      "rules": {
        "no-base-to-string": "off",
        "no-unnecessary-boolean-literal-compare": "off",
        "no-unnecessary-template-expression": "off",
        "no-unsafe-type-assertion": "off",
        "unbound-method": "off"
      }
    },
    {
      // We still allow CJS in some places, for legacy reasons
      "files": ["scripts/**/*", "**/*.cjs", "**/*.cts.ts", "**/perf/**/*"],
      "rules": {
        "import/no-commonjs": "off",
        "no-restricted-globals": "off"
      }
    },
    {
      // Vitest matchers legitimately use `this` context for matcher API
      "files": ["**/test/matchers/**/*.ts"],
      "rules": {
        "oxc/no-this-in-exported-function": "off"
      }
    },
    {
      "files": ["e2e/**/*"],
      "rules": {
        "eslint/no-console": "off"
      }
    },
    {
      "files": ["dev/test-studio/**/*"],
      "rules": {
        "eslint/no-console": "off",
        "no-explicit-any": "off",
        "jsx_a11y/iframe-has-title": "off",
        "react/iframe-missing-sandbox": "off",
        "unicorn/prefer-array-find": "off",
        "no-restricted-globals": "off",
        "import/no-commonjs": "off"
      }
    },
    {
      "files": ["dev/design-studio/**/*"],
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    },
    {
      "files": ["packages/@repo/test-dts-exports/**/*"],
      "rules": {
        "no-console": "off",
        "no-await-in-loop": "off",
        "no-explicit-any": "off",
        "no-unused-vars": "error",
        "no-unnecessary-type-arguments": "off",
        // Generated dts-export fixtures use top-level type imports and need no extension handling
        "import/extensions": "off",
        "import/consistent-type-specifier-style": "off",
        "typescript/consistent-type-imports": "off"
      }
    },
    {
      "files": ["packages/@repo/bundle-manager/**/*"],
      "rules": {
        "eslint/no-console": "off"
      }
    },
    {
      "files": ["packages/@repo/release-notes/**/*"],
      "rules": {
        "eslint/no-console": "off"
      }
    },
    {
      "files": ["packages/sanity/test/cli/**/*", "packages/sanity/src/core/config/__tests__/**/*"],
      "rules": {
        "tsdoc/syntax": "off"
      }
    },
    {
      // i18n linting only applies to the studio packages
      "files": ["packages/sanity/**", "packages/@sanity/vision/**"],
      "rules": {
        // TODO(oxlint): staged as warn. The JS plugin doesn't honor some `eslint-disable-next-line`
        // directives on multi-line JSX (10 of 23 existing intentional disables), so error would
        // produce false positives. Promote back to error once oxlint honors those directives.
        "i18next/no-literal-string": "warn",
        "@sanity/i18n/no-attribute-string-literals": [
          "error",
          {
            "ignores": {
              "componentPatterns": ["motion$"],
              "attributes": [
                "animate",
                "closed",
                "documentType",
                "edge",
                "exit",
                "fill",
                "full",
                "initial",
                "size",
                "sortOrder",
                "status",
                "group",
                "textWeight",
                "showChangesBy",
                "$area"
              ]
            }
          }
        ],
        "@sanity/i18n/no-attribute-template-literals": "error",
        "@sanity/i18n/no-i18next-import": "error"
      }
    },
    {
      // @sanity/vision has been fully migrated off styled-components to vanilla-extract,
      // so ban all styled-components imports here (oxlint overrides replace, rather than
      // merge, the global no-restricted-imports rule, so the other restrictions are repeated)
      "files": ["packages/@sanity/vision/**"],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "styled-components",
                "message": "styled-components is banned in @sanity/vision. Please use vanilla-extract (`@vanilla-extract/css`) in a `.css.ts` file instead."
              },
              {
                "name": "react",
                "importNames": ["default"],
                "message": "Please use named imports, e.g. `import {useEffect, useMemo, type ComponentType} from 'react'` instead."
              },
              {
                "name": "react",
                "importNames": ["createElement"],
                "message": "Please use JSX instead of createElement, for example `createElement(Icon)` should be `<Icon />`"
              },
              {
                "name": "react",
                "importNames": ["createRef"],
                "message": "Please use useRef instead of createRef, unless it's for a legacy React.Component class"
              },
              {
                "name": "react/jsx-runtime",
                "message": "Do not attempt importing from the jsx runtime manually, instead use JSX syntax and let the bundler transform it"
              },
              {
                "name": "react/jsx-dev-runtime",
                "message": "Do not attempt importing from the jsx runtime manually, instead use JSX syntax and let the bundler transform it"
              },
              {
                "name": "react/compiler-runtime",
                "message": "Do not attempt importing from the compiler runtime manually, instead let react compiler transform it"
              },
              {
                "name": "date-fns",
                "message": "Import from individual modules instead, e.g. `import {startOfDay} from 'date-fns/startOfDay'`. Barrel imports are ~50% slower."
              },
              {
                "name": "lodash-es",
                "message": "Import from individual modules instead, e.g. `import debounce from 'lodash-es/debounce.js'`. Barrel imports are ~55% slower."
              }
            ],
            "patterns": [
              {
                "group": ["lodash.*", "lodash/*", "lodash"],
                "message": "Please use individual imports from 'lodash-es' instead, e.g. `import debounce from 'lodash-es/debounce.js'`."
              },
              {
                "group": ["lodash-es/*", "!lodash-es/*.js"],
                "message": "lodash-es submodule imports must include the .js extension, e.g. `import debounce from 'lodash-es/debounce.js'`."
              }
            ]
          }
        ]
      }
    },
    {
      // No i18n enforcement in tests, debug tooling, or scheduled-publishing (being deprecated)
      "files": [
        "**/*/test/**/*",
        "**/*/__tests__/**/*",
        "**/*.test.{js,ts,tsx}",
        "packages/sanity/**/scheduledPublishing/**/*",
        "packages/sanity/**/scheduled-publishing/**/*",
        "packages/sanity/**/debug/**/*"
      ],
      "rules": {
        "i18next/no-literal-string": "off",
        "@sanity/i18n/no-attribute-string-literals": "off",
        "@sanity/i18n/no-attribute-template-literals": "off"
      }
    },
    {
      // Known exception: vitest suite prevents switching this import to 'sanity'
      "files": ["packages/sanity/src/ui-components/dialog/Dialog.tsx"],
      "rules": {
        "@sanity/i18n/no-i18next-import": "off"
      }
    },
    {
      // Architectural boundaries for the sanity package
      "files": ["packages/sanity/**"],
      "rules": {
        "boundaries/entry-point": "error",
        "boundaries/external": "error",
        "boundaries/dependencies": [
          "error",
          {
            "default": "disallow",
            "rules": [
              {
                "from": {"type": "sanity/_internal"},
                "allow": {"to": {"type": "sanity/_internal__contents"}}
              },
              {
                "from": {"type": "sanity/_internal__contents"},
                "allow": {"to": {"type": ["sanity", "sanity/_internal__contents"]}}
              },
              {"from": {"type": "sanity/cli"}, "allow": {"to": {"type": "sanity/cli__contents"}}},
              {
                "from": {"type": "sanity/cli__contents"},
                "allow": {"to": {"type": "sanity/cli__contents"}}
              },
              {"from": {"type": "sanity"}, "allow": {"to": {"type": "sanity__contents"}}},
              {
                "from": {"type": "sanity__contents"},
                "allow": {
                  "to": {"type": ["sanity__contents", "sanity/router", "sanity/_singletons"]}
                }
              },
              {
                "from": {"type": "sanity/desk"},
                "allow": {
                  "to": {
                    "type": [
                      "sanity/desk__contents",
                      "sanity/structure",
                      "sanity/structure__contents"
                    ]
                  }
                }
              },
              {
                "from": {"type": "sanity/desk__contents"},
                "allow": {
                  "to": {
                    "type": [
                      "sanity",
                      "sanity/desk__contents",
                      "sanity/router",
                      "sanity/_internal",
                      "sanity/structure",
                      "sanity/structure__contents",
                      "sanity/_singletons"
                    ]
                  }
                }
              },
              {
                "from": {"type": "sanity/router"},
                "allow": {"to": {"type": "sanity/router__contents"}}
              },
              {
                "from": {"type": "sanity/router__contents"},
                "allow": {"to": {"type": ["sanity/router__contents", "sanity/_singletons"]}}
              },
              {
                "from": {"type": "sanity/structure"},
                "allow": {"to": {"type": "sanity/structure__contents"}}
              },
              {
                "from": {"type": "sanity/structure__contents"},
                "allow": {
                  "to": {
                    "type": [
                      "sanity",
                      "sanity/structure__contents",
                      "sanity/router",
                      "sanity/_singletons"
                    ]
                  }
                }
              },
              {
                "from": {"type": "sanity/_singletons"},
                "allow": {"to": {"type": "sanity/_singletons__contents"}}
              },
              {
                "from": {"type": "sanity/_singletons__contents"},
                "allow": {"to": {"type": "sanity/_singletons__contents"}}
              },
              {
                "from": {"type": "sanity/_singletons__contents"},
                "allow": {
                  "to": {
                    "type": [
                      "sanity__contents",
                      "sanity/structure__contents",
                      "sanity/router__contents"
                    ]
                  },
                  "dependency": {"kind": "type"}
                }
              },
              {
                "from": {"type": "sanity/_singletons__contents"},
                "disallow": {
                  "to": {"type": ["sanity", "sanity/structure", "sanity/router"]},
                  "dependency": {"kind": "type"}
                }
              }
            ]
          }
        ]
      }
    },
    {
